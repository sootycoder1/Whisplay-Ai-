def test_display_ui():
    section("DISPLAY UI")

    ui = safe_import("display_ui")

    if ui is None:
        return False

    print("[INFO] display_ui loaded")

    # Only call functions if they exist.
    # This avoids guessing your exact UI API.
    candidates = [
        ("set_idle", ("Local UI test: idle",)),
        ("set_thinking", ("Local UI test: thinking",)),
        ("set_speaking", ("Local UI test: speaking",)),
        ("set_error", ("Local UI test: error check",)),
    ]

    any_called = False

    for name, args in candidates:
        fn = getattr(ui, name, None)

        if callable(fn):
            safe_call(f"display_ui.{name}", fn, *args)
            any_called = True
            time.sleep(0.4)
        else:
            print(f"[SKIP] display_ui.{name} not found")

    if not any_called:
        print("[WARN] display_ui imported, but no known UI functions found")

    return True



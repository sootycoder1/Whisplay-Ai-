def section(name):
    print("\n" + "=" * 55)
    print(name)
    print("=" * 55)


def safe_import(module_name):
    try:
        module = __import__(module_name)
        print(f"[OK] import {module_name}")
        return module
    except Exception as e:
        print(f"[FAIL] import {module_name}: {e}")
        traceback.print_exc()
        return None


def safe_call(label, fn, *args, **kwargs):
    try:
        result = fn(*args, **kwargs)
        print(f"[OK] {label}")
        return result
    except Exception as e:
        print(f"[FAIL] {label}: {e}")
        traceback.print_exc()
        return None


